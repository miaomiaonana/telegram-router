# Telegram bot
TELEGRAM_BOT_TOKEN=

# Required only for user-account listening mode.
# Get these from https://my.telegram.org/apps.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_USER_SESSION=

# Forum group id. Source and target topics are in this same group.
TELEGRAM_CHAT_ID=

# Source topic ids. Leave empty to listen to every topic in TELEGRAM_CHAT_ID.
# For multiple source topics, use commas: 11,22
SOURCE_TOPIC_IDS=

# Topic ids in the target forum group.
STOCK_TOPIC_ID=
TRADING_TOPIC_ID=
SUMMARY_TOPIC_ID=
WATCH_TOPIC_ID=
WATCHLIST_FILE=watchlist.json
ALERT_STATE_FILE=alert-state.json
WATCH_MONITOR_INTERVAL_MINUTES=5
VALUE_TOPIC_ID=
VALUE_WATCHLIST_FILE=value-watchlist.json
VALUE_ALERT_STATE_FILE=value-alert-state.json
COINGLASS_API_KEY=
COINGLASS_BASE_URL=https://open-api-v4.coinglass.com

# Forwarding rules are fixed in code:
# - content containing "用户所属分组: 美股" goes to STOCK_TOPIC_ID
# - content containing "用户所属分组: 交易" goes to TRADING_TOPIC_ID

# Summary schedule.
SUMMARY_INTERVAL_MINUTES=240
SUMMARY_COMMAND=/summary2h
SUMMARY_COMMAND_ALIASES=/ai_summary2h
SUMMARY_COMMAND_HOURS=2
SUMMARY_HISTORY_HOURS=24
MAX_SUMMARY_MESSAGES=80
SUMMARY_MAX_OUTPUT_TOKENS=4096

# Optional AI summary. If empty, the service sends a simpler local summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
